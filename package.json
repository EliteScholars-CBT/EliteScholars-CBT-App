{
  "name": "react",
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@vercel/kv": "^1.0.1",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-router-dom": "^7.5.1",
    "recharts": "^2.10.3",
    "resend": "^3.2.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "obfuscate": "javascript-obfuscator build/static/js --output build/static/js --compact true --string-array true --rotate-string-array true --string-array-threshold 0.75 --dead-code-injection false --self-defending true --disable-console-output true",
    "build:prod": "react-scripts build && npm run obfuscate",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "javascript-obfuscator": "^4.2.2",
    "prettier": "^3.8.3",
    "react-scripts": "latest"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}